---
import { renderInlineMarkdown } from '../utils/inlineMarkdown';
import { getCollection } from 'astro:content';

const { page } = Astro.props;

const portfolioItems = (await getCollection('portfolio', ({ data }) => data.published !== false))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99) || a.data.title.localeCompare(b.data.title))
  .slice(0, 6);

const heroTitle = page.data.heroTitle ?? page.data.title;
const heroText = page.data.heroText;
const heroKicker = page.data.heroKicker ?? 'Fresh nonsense, useful art';
const heroBackgroundImage = page.data.heroBackgroundImage ?? '/media/home-hero.svg';
const heroBackgroundPosition = page.data.heroBackgroundPosition ?? 'center center';
const heroMailtoEmail = page.data.heroMailtoEmail;
const heroMailtoLabel = page.data.heroMailtoLabel ?? 'Email me';
const heroBullets = (page.data.heroBullets ?? '')
  .split('\n')
  .map((item: string) => item.trim())
  .filter(Boolean);

const hasLandingBody = Boolean(page.body?.trim());
const heroMailtoHref = heroMailtoEmail ? `mailto:${heroMailtoEmail}` : '';
const heroTextHtml = renderInlineMarkdown(heroText);
---

<section
  class="landing-hero"
  aria-labelledby="landing-title"
  style={`--landing-hero-image: url('${heroBackgroundImage}'); --landing-hero-position: ${heroBackgroundPosition};`}
>
  <div class="landing-hero-scrim" aria-hidden="true"></div>

  <div class="hero-copy">
    <p class="scribble-kicker">{heroKicker}</p>
    <h1 id="landing-title" class="scribble-title">{heroTitle}</h1>

    {heroText && <p class="landing-intro" set:html={heroTextHtml} />}

    {heroMailtoHref && (
      <a class="landing-mailto" href={heroMailtoHref}>{heroMailtoLabel}</a>
    )}
    {heroBullets.length > 0 && (
      <ul class="scribble-list">
        {heroBullets.map((item: string) => <li>{item}</li>)}
      </ul>
    )}
  </div>
</section>

{hasLandingBody && (
  <section class="landing-note prose" aria-label="Homepage introduction">
    <slot />
  </section>
)}

<section id="portfolio" class="portfolio-wall" aria-labelledby="portfolio-title">
  <div class="section-rule" aria-hidden="true"></div>
  <div class="portfolio-heading">
    <p class="scribble-kicker">Portfolio</p>
    <h2 id="portfolio-title">A wall of doodles, projects and odd little things.</h2>
  </div>

  <div class="portfolio-grid">
    {portfolioItems.map((item, index) => (
      <article class={`portfolio-card portfolio-card-${index + 1}`}>
        <a href={item.data.link || '#'} aria-label={`Open ${item.data.title}`}>
          {item.data.image ? (
            <img src={item.data.image} alt="" loading="lazy" />
          ) : (
            <div class="portfolio-placeholder" aria-hidden="true">
              <span>{index + 1}</span>
            </div>
          )}
          <div class="portfolio-caption">
            <h3>{item.data.title}</h3>
            {item.data.description && <p>{item.data.description}</p>}
          </div>
        </a>
      </article>
    ))}
  </div>
</section>
