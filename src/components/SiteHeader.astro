---
import { getCollection } from 'astro:content';

const navPages = (await getCollection('pages', ({ data }) => data.published !== false && data.showInNav !== false))
  .sort((a, b) => (a.data.navOrder ?? 99) - (b.data.navOrder ?? 99) || a.data.title.localeCompare(b.data.title));

const toUrl = (id: string) => {
  const clean = id.replace(/(^|\/)index$/, '').replace(/\/+/g, '/');
  return clean ? `/${clean}/` : '/';
};
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Snoodle Doodles HQ home">
    <span class="brand-main">Snoodle Doodles</span><sup>HQ</sup>
  </a>

  <nav class="site-nav" aria-label="Main navigation">
    {navPages.map((page) => (
      <a href={toUrl(page.id)}>{page.data.title}</a>
    ))}
  </nav>

  <div class="header-actions" aria-label="Shop actions">
    <a class="shop-button" href="/shop/">Shop!</a>
    <a class="cart-link" href="/checkout/" aria-label="Shopping basket, 0 items">
      <svg aria-hidden="true" viewBox="0 0 48 32" width="38" height="26">
        <path d="M5 5h6l4 17h21l5-12H16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <circle cx="20" cy="27" r="2.6" fill="currentColor"></circle>
        <circle cx="34" cy="27" r="2.6" fill="currentColor"></circle>
        <path d="M2 11c6 1 7-2 11-1" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      </svg>
      <span class="cart-count" data-cart-count>0</span>
    </a>
  </div>
</header>

<script is:inline>
  const CART_KEY = 'snoodle-doodles-cart';

  const readCartCount = () => {
    try {
      const raw = localStorage.getItem(CART_KEY);
      const cart = raw ? JSON.parse(raw) : [];
      return Array.isArray(cart)
        ? cart.reduce((total, item) => total + Number(item?.qty || 0), 0)
        : 0;
    } catch {
      return 0;
    }
  };

  const syncCartCount = () => {
    const count = readCartCount();
    document.querySelectorAll('[data-cart-count]').forEach((node) => {
      node.textContent = String(count);
    });

    document.querySelectorAll('.cart-link').forEach((link) => {
      link.setAttribute('aria-label', `Shopping basket, ${count} item${count === 1 ? '' : 's'}`);
    });
  };

  syncCartCount();
  window.addEventListener('storage', syncCartCount);
  window.addEventListener('cart:update', syncCartCount);
  window.addEventListener('pageshow', syncCartCount);
</script>
