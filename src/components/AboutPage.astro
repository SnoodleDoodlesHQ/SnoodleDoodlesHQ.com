---
import { renderInlineMarkdown } from '../utils/inlineMarkdown';
import type { CollectionEntry } from 'astro:content';

interface Props {
  page: CollectionEntry<'pages'>;
}

const { page } = Astro.props;

const bioTitle = page.data.bioTitle ?? 'About Me';
const bioImage = page.data.bioImage ?? '/media/about-profile-placeholder.svg';
const bioBody = page.data.bioBody ?? '';
const email = page.data.email;
const emailLabel = page.data.emailLabel ?? 'Email me';
const mailtoHref = email ? `mailto:${email}` : '';
const bioDownloadFile = page.data.bioDownloadFile ?? '/media/about-bio-placeholder.pdf';
const bioDownloadLabel = page.data.bioDownloadLabel ?? 'Download bio PDF';

const fullBioTitle = page.data.fullBioTitle ?? 'Full Bio';
const fullBioText = page.data.fullBioText ?? '';
const fullBioImage = page.data.fullBioImage ?? '/media/about-full-bio-placeholder.svg';

const bioBodyHtml = renderInlineMarkdown(bioBody);
const fullBioTextHtml = renderInlineMarkdown(fullBioText);
---

<section class="about-bio-hero" aria-labelledby="about-bio-title">
  <div class="about-profile-image-wrap">
    <img class="about-profile-image" src={bioImage} alt="" loading="eager" />
  </div>

  <div class="about-bio-copy">
    <p class="scribble-kicker">Bio</p>
    <h1 id="about-bio-title">{bioTitle}</h1>
    {bioBody && <p set:html={bioBodyHtml} />}
    <div class="about-action-links">
      {bioDownloadFile && (
        <a class="about-download-link" href={bioDownloadFile} download>{bioDownloadLabel}</a>
      )}

      {mailtoHref && (
        <a class="about-mailto-link" href={mailtoHref}>{emailLabel}</a>
      )}
    </div>
  </div>
</section>

<section class="about-full-bio" aria-labelledby="about-full-bio-title">
  <div class="section-rule" aria-hidden="true"></div>
  <h2 id="about-full-bio-title">{fullBioTitle}</h2>

  <div class="about-full-bio-grid">
    <div class="about-full-bio-text">
      {fullBioText && <p set:html={fullBioTextHtml} />}
    </div>

    <figure class="about-full-bio-image-wrap">
      <img src={fullBioImage} alt="" loading="lazy" />
    </figure>
  </div>
</section>
