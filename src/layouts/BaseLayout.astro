---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CallToArms from '../components/CallToArms.astro';
import '../styles/global.css';

const {
  title = 'Snoodle Doodle HQ',
  description = 'A simple editable Astro site powered by Pages CMS.',
} = Astro.props;

const isLandingPage = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class={isLandingPage ? 'body-landing' : undefined}>
    <div class={isLandingPage ? 'site-shell is-landing-shell' : 'site-shell'}>
      <SiteHeader />
      <main>
        <slot />
      </main>
      <CallToArms />
      <SiteFooter />
    </div>
  </body>
</html>
