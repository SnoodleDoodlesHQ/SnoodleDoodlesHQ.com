---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingPage from '../components/LandingPage.astro';

const page = await getEntry('pages', 'index');

if (!page || page.data.published === false) {
  throw new Error('Missing published homepage content at src/content/pages/index.md');
}

const { Content } = await render(page);
const title = page.data.title === 'Home' ? 'Snoodle Doodles HQ' : `${page.data.title} | Snoodle Doodles HQ`;
---

<BaseLayout title={title} description={page.data.description}>
  <LandingPage page={page}>
    <Content />
  </LandingPage>
</BaseLayout>
