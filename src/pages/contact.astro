---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactPage from '../components/ContactPage.astro';

const page = await getEntry('pages', 'contact');

if (!page || page.data.published === false) {
  throw new Error('Missing published contact page content at src/content/pages/contact.md');
}

const { Content } = await render(page);
const title = `${page.data.title} | Snoodle Doodles HQ`;
---

<BaseLayout title={title} description={page.data.description}>
  <ContactPage page={page.data}>
    <Content />
  </ContactPage>
</BaseLayout>
