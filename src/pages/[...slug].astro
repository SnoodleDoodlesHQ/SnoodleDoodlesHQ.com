---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => data.published !== false);

  return pages
    .filter((page) => !['index', 'contact', 'personal'].includes(page.id))
    .map((page) => {
      const clean = page.id.replace(/(^|\/)index$/, '').replace(/\/+/g, '/');

      return {
        params: { slug: clean },
        props: { page },
      };
    });
}

const { page } = Astro.props;
const { Content } = await render(page);
const title = `${page.data.title} | Snoodle Doodles HQ`;
const heroTitle = page.data.heroTitle ?? page.data.title;
---

<BaseLayout title={title} description={page.data.description}>
  <section class="page-hero">
    <p class="scribble-kicker">Snoodle Doodles HQ</p>
    <h1>{heroTitle}</h1>
    {page.data.heroText && <p class="hero-text">{page.data.heroText}</p>}
  </section>

  <article class="content-card prose">
    <Content />
  </article>
</BaseLayout>
