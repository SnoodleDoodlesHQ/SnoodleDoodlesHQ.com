---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Message sent | Snoodle Doodles HQ" description="Thank you for contacting Snoodle Doodles HQ.">
  <section class="page-hero contact-success-hero">
    <p class="scribble-kicker">Message sent</p>
    <h1>Got it.</h1>
    <p class="hero-text">Thanks for the message. If Netlify Forms is enabled on the deployed site, the submission will be saved in Netlify and sent to the configured notification email.</p>
    <p class="contact-success-link"><a class="shop-button" href="/">Back home</a></p>
  </section>
</BaseLayout>
