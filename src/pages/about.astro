---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutPage from '../components/AboutPage.astro';

const page = await getEntry('pages', 'about');

if (!page) {
  throw new Error('Missing about page content: src/content/pages/about.md');
}
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <AboutPage page={page} />
</BaseLayout>
